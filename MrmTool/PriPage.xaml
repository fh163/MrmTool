<Page
    x:Class="MrmTool.PriPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:MrmTool"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:MrmTool.Models"
    xmlns:wct="using:CommunityToolkit.WinUI.Controls"
    xmlns:interactivity="using:Microsoft.Xaml.Interactivity"
    xmlns:behaviors="using:CommunityToolkit.WinUI.Behaviors"
    xmlns:mbehaviors="using:MrmTool.Behaviors"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:selectors="using:MrmTool.Selectors"
    xmlns:winuieditor="using:WinUIEditor"
    xmlns:selectorsContract5Present="using:MrmTool.Selectors?IsApiContractPresent(Windows.Foundation.UniversalApiContract,5)"
    xmlns:selectorsContract5NotPresent="using:MrmTool.Selectors?IsApiContractNotPresent(Windows.Foundation.UniversalApiContract,5)"
    xmlns:contract7Present="http://schemas.microsoft.com/winfx/2006/xaml/presentation?IsApiContractPresent(Windows.Foundation.UniversalApiContract,7)"
    xmlns:contract5Present="http://schemas.microsoft.com/winfx/2006/xaml/presentation?IsApiContractPresent(Windows.Foundation.UniversalApiContract,5)"
    xmlns:contract5NotPresent="http://schemas.microsoft.com/winfx/2006/xaml/presentation?IsApiContractNotPresent(Windows.Foundation.UniversalApiContract,5)"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
    
    <Page.Resources>
        <contract5NotPresent:DataTemplate x:Key="ResourceTemplateOld" x:DataType="models:ResourceItem">
            <muxc:TreeViewItemWrapper AutomationProperties.Name="{x:Bind DisplayName, Mode = OneWay}"
                          ItemsSource="{x:Bind Children}" Margin="0,2,0,2" Background="Transparent">
                <StackPanel Orientation="Horizontal">
                    <Image Width="28" Source="{x:Bind Icon, Mode = OneWay}" Margin="0,0,10,0" />
                    <TextBlock Text="{x:Bind DisplayName, Mode = OneWay}" VerticalAlignment="Center" />
                </StackPanel>
                <muxc:TreeViewItemWrapper.ContextFlyout>
                    <MenuFlyout>
                        <MenuFlyoutItem Text="添加资源" Visibility="{x:Bind IsFolder}" Click="AddResource_Click">
                            <MenuFlyoutItem.Icon>
                                <SymbolIcon Symbol="Add" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutSubItem Text="重命名">
                            <MenuFlyoutSubItem.Icon>
                                <SymbolIcon Symbol="Rename" />
                            </MenuFlyoutSubItem.Icon>
                            <MenuFlyoutItem Text="简单重命名" Click="SimpleRename_Click" />
                            <MenuFlyoutItem Text="完整重命名" Click="FullRename_Click" />
                        </MenuFlyoutSubItem>
                        <MenuFlyoutItem Text="删除" Click="RemoveResources_Click">
                            <MenuFlyoutItem.Icon>
                                <SymbolIcon Symbol="Delete" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                    </MenuFlyout>
                </muxc:TreeViewItemWrapper.ContextFlyout>
            </muxc:TreeViewItemWrapper>
        </contract5NotPresent:DataTemplate>
        <contract5Present:DataTemplate x:Key="ResourceTemplate" x:DataType="models:ResourceItem">
            <muxc:TreeViewItem AutomationProperties.Name="{x:Bind DisplayName, Mode = OneWay}"
                        ItemsSource="{x:Bind Children}" Margin="0,2,0,2" Background="Transparent">
                <StackPanel Orientation="Horizontal">
                    <Image Width="28" Source="{x:Bind Icon, Mode = OneWay}" Margin="0,0,10,0" />
                    <TextBlock Text="{x:Bind DisplayName, Mode = OneWay}" VerticalAlignment="Center" />
                </StackPanel>
                <muxc:TreeViewItem.ContextFlyout>
                    <MenuFlyout>
                        <MenuFlyoutItem Text="添加资源" Visibility="{x:Bind IsFolder}" Click="AddResource_Click">
                            <MenuFlyoutItem.Icon>
                                <SymbolIcon Symbol="Add" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutSubItem Text="重命名">
                            <MenuFlyoutSubItem.Icon>
                                <SymbolIcon Symbol="Rename" />
                            </MenuFlyoutSubItem.Icon>
                            <MenuFlyoutItem Text="简单重命名" Click="SimpleRename_Click" />
                            <MenuFlyoutItem Text="完整重命名" Click="FullRename_Click" />
                        </MenuFlyoutSubItem>
                        <MenuFlyoutItem Text="删除" Click="RemoveResources_Click">
                            <MenuFlyoutItem.Icon>
                                <SymbolIcon Symbol="Delete" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                    </MenuFlyout>
                </muxc:TreeViewItem.ContextFlyout>
            </muxc:TreeViewItem>
        </contract5Present:DataTemplate>
        <selectors:ResourceItemTemplateSelector x:Key="ResourceItemTemplateSelector"
            selectorsContract5Present:Resource="{StaticResource ResourceTemplate}"
            selectorsContract5NotPresent:Resource="{StaticResource ResourceTemplateOld}" />
    </Page.Resources>
    <Grid Background="Transparent" AllowDrop="True" DragOver="Grid_DragOver" Drop="Grid_Drop">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <muxc:MenuBar Grid.Row="0">
            <muxc:MenuBarItem Title="文件">
                <MenuFlyoutItem Text="打开" Click="Open_Click">
                    <MenuFlyoutItem.Icon>
                        <SymbolIcon Symbol="OpenFile" />
                    </MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
                <MenuFlyoutItem Text="保存" Click="Save_Click">
                    <MenuFlyoutItem.Icon>
                        <SymbolIcon Symbol="Save" />
                    </MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
                <MenuFlyoutItem Text="另存为" Click="SaveAs_Click">
                    <MenuFlyoutItem.Icon>
                        <SymbolIcon Symbol="SaveLocal" />
                    </MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
                <MenuFlyoutSeparator />
                <MenuFlyoutItem Text="退出" Click="Exit_Click">
                    <MenuFlyoutItem.Icon>
                        <SymbolIcon Symbol="Cancel" />
                    </MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
            </muxc:MenuBarItem>
            <muxc:MenuBarItem Title="编辑">
                <MenuFlyoutItem Text="添加资源" Click="AddResource_Click">
                    <MenuFlyoutItem.Icon>
                        <SymbolIcon Symbol="Add" />
                    </MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
                <MenuFlyoutItem x:Name="RemoveResourcesItem" Text="移除选中的资源" IsEnabled="False" Click="RemoveResources_Click">
                    <MenuFlyoutItem.Icon>
                        <SymbolIcon Symbol="Delete" />
                    </MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
                <MenuFlyoutSeparator />
                <MenuFlyoutItem Text="设置根目录" Click="SetRootFolder_Click">
                    <MenuFlyoutItem.Icon>
                        <SymbolIcon Symbol="OpenLocal" />
                    </MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
                <MenuFlyoutItem Text="嵌入路径资源到" Click="EmbedPathResources_Click">
                    <MenuFlyoutItem.Icon>
                        <SymbolIcon Symbol="ImportAll" />
                    </MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
            </muxc:MenuBarItem>
            <muxc:MenuBarItem Title="视图">
                <ToggleMenuFlyoutItem Visibility="{x:Bind local:Program.IsWebViewAvailable}" Text="SVG 使用 WebView 预览" Click="UseWebViewForSvg_Click">
                    <ToggleMenuFlyoutItem.Icon>
                        <SymbolIcon Symbol="Globe" />
                    </ToggleMenuFlyoutItem.Icon>
                </ToggleMenuFlyoutItem>
                <MenuFlyoutSubItem Text="预览器主题">
                    <muxc:RadioMenuFlyoutItem Text="系统" GroupName="PreviewerTheme" Click="SystemTheme_Click" IsChecked="True" />
                    <muxc:RadioMenuFlyoutItem Text="浅色" GroupName="PreviewerTheme" Click="LightTheme_Click" />
                    <muxc:RadioMenuFlyoutItem Text="深色" GroupName="PreviewerTheme" Click="DarkTheme_Click" />
                    <MenuFlyoutSubItem.Icon>
                        <FontIcon Glyph="&#xF08C;" />
                    </MenuFlyoutSubItem.Icon>
                </MenuFlyoutSubItem>
            </muxc:MenuBarItem>
            <muxc:MenuBarItem Title="帮助">
                <MenuFlyoutItem Text="第三方声明" Click="Notice_Click">
                    <MenuFlyoutItem.Icon>
                        <SymbolIcon Symbol="ContactInfo" />
                    </MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
            </muxc:MenuBarItem>
        </muxc:MenuBar>
        <Grid Grid.Row="1" Margin="0,5,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" MinWidth="280" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <!-- ====================================== -->
            <!-- 👇 【保留】TreeView 汉化功能右键菜单（真功能，不是样子）👇 -->
            <!-- ====================================== -->
            <muxc:TreeView x:Name="treeView" Grid.Column="0" CanDragItems="False" CanReorderItems="False" ItemsSource="{x:Bind ResourceItems}" ItemTemplateSelector="{StaticResource ResourceItemTemplateSelector}" SelectionChanged="treeView_SelectionChanged">
                <treeView.ContextFlyout>
                    <MenuFlyout Opening="PriMenuFlyout_Opening">
                        <MenuFlyoutItem x:Name="miExportPri" Text="导出 PRI 文件" Click="ExportPriFile_Click">
                            <MenuFlyoutItem.Icon>
                                <SymbolIcon Symbol="Save" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem x:Name="miImportLang" Text="导入中文汉化包" Click="ImportChineseLang_Click">
                            <MenuFlyoutItem.Icon>
                                <SymbolIcon Symbol="Import" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem x:Name="miRebuildPri" Text="重新生成 PRI" Click="RebuildPri_Click">
                            <MenuFlyoutItem.Icon>
                                <SymbolIcon Symbol="Sync" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutSeparator />
                        <MenuFlyoutItem x:Name="miRefresh" Text="刷新资源列表" Click="RefreshResourceList_Click">
                            <MenuFlyoutItem.Icon>
                                <SymbolIcon Symbol="Refresh" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                    </MenuFlyout>
                </treeView.ContextFlyout>
            </muxc:TreeView>
            <Grid Grid.Column="2" VerticalAlignment="Stretch">
                <Grid.RowDefinitions>
                    <RowDefinition Height="180" MinHeight="130" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="*" MinHeight="130" />
                </Grid.RowDefinitions>
                
                <Border Grid.Row="0" Margin="16,0,10.5,10.5" BorderThickness="0.5" CornerRadius="8">
                    <Border.BorderBrush>
                        <SolidColorBrush Color="{ThemeResource TextFillColorSecondary}" Opacity="0.4" />
                    </Border.BorderBrush>
                    <Grid>
                        <ListView x:Name="candidatesList" SelectionChanged="candidatesList_SelectionChanged">
                            <ListView.Header>
                                <Border Background="{ThemeResource SolidBackgroundFillColorTertiaryBrush}">
                                    <interactivity:Interaction.Behaviors>
                                        <behaviors:StickyHeaderBehavior />
                                    </interactivity:Interaction.Behaviors>
                                    <wct:DataTable Margin="10,0,0,0" Height="30">
                                        <wct:DataColumn Content="类型" Width="120" MinWidth="100" CanResize="True" />
                                        <wct:DataColumn Content="限定符" />
                                    </wct:DataTable>
                                </Border>
                            </ListView.Header>
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Left" />
                                    <Setter Property="VerticalContentAlignment" Value="Stretch" />
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:CandidateItem">
                                    <Grid Background="Transparent">
                                        <wct:DataRow HorizontalAlignment="Left">
                                            <TextBlock Text="{x:Bind Type, Mode = OneWay}" VerticalAlignment="Center" />
                                            <TextBlock Text="{x:Bind Qualifiers, Mode = OneWay}" VerticalAlignment="Center" />
                                        </wct:DataRow>
                                        <Grid.ContextFlyout>
                                            <MenuFlyout>
                                                <MenuFlyoutItem Text="导出" Visibility="{x:Bind IsExportable, Mode = OneWay}" Click="ExportButton_Click">
                                                    <MenuFlyoutItem.Icon>
                                                        <SymbolIcon Symbol="Save" />
                                                    </MenuFlyoutItem.Icon>
                                                </MenuFlyoutItem>
                                                <MenuFlyoutItem Text="在资源管理器中显示" Visibility="{x:Bind IsPathCandidate, Mode = OneWay}" Click="OpenFolder_Click">
                                                    <MenuFlyoutItem.Icon>
                                                        <SymbolIcon Symbol="Folder" />
                                                    </MenuFlyoutItem.Icon>
                                                </MenuFlyoutItem>
                                                <MenuFlyoutItem Text="嵌入到 PRI 文件" Visibility="{x:Bind IsPathCandidate, Mode = OneWay}" Click="EmbedPathCandidate_Click">
                                                    <MenuFlyoutItem.Icon>
                                                        <SymbolIcon Symbol="Import" />
                                                    </MenuFlyoutItem.Icon>
                                                </MenuFlyoutItem>
                                                <MenuFlyoutItem Text="修改" Click="CreateOrModifyCandidate_Click">
                                                    <MenuFlyoutItem.Icon>
                                                        <SymbolIcon Symbol="Edit" />
                                                    </MenuFlyoutItem.Icon>
                                                </MenuFlyoutItem>
                                                <MenuFlyoutItem Text="删除" Click="DeleteCandiate_Click">
                                                    <MenuFlyoutItem.Icon>
                                                        <SymbolIcon Symbol="Delete" />
                                                    </MenuFlyoutItem.Icon>
                                                </MenuFlyoutItem>
                                            </MenuFlyout>
                                        </Grid.ContextFlyout>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                        <Viewbox ToolTipService.ToolTip="添加候选" Width="28" Height="28" Margin="0,2,2,0" VerticalAlignment="Top" HorizontalAlignment="Right" Tapped="CreateOrModifyCandidate_Click">
                            <Grid Padding="5" Background="Transparent">
                                <SymbolIcon x:Name="addSymbol" Symbol="Add" />
                            </Grid>
                            <Viewbox.Resources>
                                <SineEase x:Name="easingFunction" EasingMode="EaseIn" />
                                <Storyboard x:Name="HoverBoard">
                                    <ColorAnimation Duration="0:0:0.2" To="#FF0078D4" Storyboard.TargetName="addSymbol" Storyboard.TargetProperty="Foreground.Color" />
                                </Storyboard>
                            </Viewbox.Resources>
                        </Viewbox>
                    </Grid>
                </Border>

                <!-- 预览区域 原有代码保留，新增文本编辑器中文右键菜单 -->
                <Border Grid.Row="2" Margin="16,0,10.5,10.5" BorderThickness="0.5" CornerRadius="8">
                    <Border.BorderBrush>
                        <SolidColorBrush Color="{ThemeResource TextFillColorSecondary}" Opacity="0.4" />
                    </Border.BorderBrush>
                    <Grid x:Name="previewContainer">
                        <Frame x:Name="webView" Visibility="Collapsed" />
                        <Grid x:Name="svgPreviewerContainer" Visibility="Collapsed">
                            <ScrollViewer>
                                <Image x:Name="svgPreviewer" Stretch="Uniform" Margin="10" />
                            </ScrollViewer>
                        </Grid>
                        <Grid x:Name="imagePreviewerContainer" Visibility="Collapsed">
                            <ScrollViewer>
                                <Image x:Name="imagePreviewer" Stretch="Uniform" Margin="10" />
                            </ScrollViewer>
                        </Grid>
                        <Grid x:Name="valueTextEditorContainer" Visibility="Collapsed">
                            <!-- ====================================== -->
                            <!-- 👇 【新增】文本编辑器中文右键菜单（替换系统英文菜单）👇 -->
                            <!-- ====================================== -->
                            <winuieditor:TextEditor x:Name="valueTextEditor">
                                <winuieditor:TextEditor.ContextFlyout>
                                    <MenuFlyout Opening="EditorMenuFlyout_Opening">
                                        <MenuFlyoutItem x:Name="miUndo" Text="撤销" Click="Undo_Click">
                                            <MenuFlyoutItem.Icon>
                                                <SymbolIcon Symbol="Undo" />
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutItem x:Name="miRedo" Text="重做" Click="Redo_Click">
                                            <MenuFlyoutItem.Icon>
                                                <SymbolIcon Symbol="Redo" />
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutSeparator />
                                        <MenuFlyoutItem x:Name="miCut" Text="剪切" Click="Cut_Click">
                                            <MenuFlyoutItem.Icon>
                                                <SymbolIcon Symbol="Cut" />
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutItem x:Name="miCopy" Text="复制" Click="Copy_Click">
                                            <MenuFlyoutItem.Icon>
                                                <SymbolIcon Symbol="Copy" />
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutItem x:Name="miPaste" Text="粘贴" Click="Paste_Click">
                                            <MenuFlyoutItem.Icon>
                                                <SymbolIcon Symbol="Paste" />
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutItem x:Name="miDelete" Text="删除" Click="Delete_Click">
                                            <MenuFlyoutItem.Icon>
                                                <SymbolIcon Symbol="Delete" />
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutSeparator />
                                        <MenuFlyoutItem x:Name="miSelectAll" Text="全选" Click="SelectAll_Click">
                                            <MenuFlyoutItem.Icon>
                                                <SymbolIcon Symbol="SelectAll" />
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                    </MenuFlyout>
                                </winuieditor:TextEditor.ContextFlyout>
                            </winuieditor:TextEditor>
                        </Grid>
                        <Grid x:Name="invalidRootPathContainer" Visibility="Collapsed">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <SymbolIcon Symbol="Error" Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
                                <TextBlock Text="无效的根目录，无法解析路径资源" TextAlignment="Center" Margin="0,10,0,0" />
                            </StackPanel>
                        </Grid>
                        <Grid x:Name="failedToOpenFileContainer" Visibility="Collapsed">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <SymbolIcon Symbol="Error" Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
                                <TextBlock Text="无法打开文件" TextAlignment="Center" Margin="0,10,0,0" />
                            </StackPanel>
                        </Grid>
                        <Grid x:Name="xbfFallbackContainer" Visibility="Collapsed">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <SymbolIcon Symbol="Document" />
                                <TextBlock Text="XBF 二进制资源，无法预览" TextAlignment="Center" Margin="0,10,0,0" />
                            </StackPanel>
                        </Grid>
                        <Grid x:Name="exportContainer" Visibility="Collapsed">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <SymbolIcon Symbol="SaveLocal" />
                                <TextBlock x:Name="fileSizeLabel" Text="文件大小" TextAlignment="Center" Margin="0,10,0,0" />
                                <Button Content="导出" Click="ExportButton_Click" Margin="0,10,0,0" />
                            </StackPanel>
                        </Grid>
                        <Grid x:Name="openFolderContainer" Visibility="Collapsed">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <SymbolIcon Symbol="Folder" />
                                <TextBlock Text="路径资源，点击按钮打开" TextAlignment="Center" Margin="0,10,0,0" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>
