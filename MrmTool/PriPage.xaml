<Page
    x:Class="MrmTool.PriPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:MrmTool"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:MrmTool.Models"
    xmlns:wct="using:CommunityToolkit.WinUI.Controls"
    xmlns:interactivity="using:Microsoft.Xaml.Interactivity"
    xmlns:behaviors="using:CommunityToolkit.WinUI.Behaviors"
    xmlns:mbehaviors="using:MrmTool.Behaviors"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:selectors="using:MrmTool.Selectors"
    xmlns:winuieditor="using:WinUIEditor"
    xmlns:selectorsContract5Present="using:MrmTool.Selectors?IsApiContractPresent(Windows.Foundation.UniversalApiContract,5)"
    xmlns:selectorsContract5NotPresent="using:MrmTool.Selectors?IsApiContractNotPresent(Windows.Foundation.UniversalApiContract,5)"
    xmlns:contract7Present="http://schemas.microsoft.com/winfx/2006/xaml/presentation?IsApiContractPresent(Windows.Foundation.UniversalApiContract,7)"
    xmlns:contract5Present="http://schemas.microsoft.com/winfx/2006/xaml/presentation?IsApiContractPresent(Windows.Foundation.UniversalApiContract,5)"
    xmlns:contract5NotPresent="http://schemas.microsoft.com/winfx/2006/xaml/presentation?IsApiContractNotPresent(Windows.Foundation.UniversalApiContract,5)"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
    
    <Page.Resources>
        <local:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" />
        <!-- 避免应用首次启动时 MenuBarItem 出现黑色焦点框。 -->
        <Thickness x:Key="MenuBarItemBorderThickness">0</Thickness>
        <SolidColorBrush x:Key="MenuBarItemBorderBrush" Color="Transparent"/>
        <SolidColorBrush x:Key="MenuBarItemBorderBrushPointerOver" Color="Transparent"/>
        <SolidColorBrush x:Key="MenuBarItemBorderBrushPressed" Color="Transparent"/>
        <SolidColorBrush x:Key="MenuBarItemBorderBrushSelected" Color="Transparent"/>
        <!-- 使用极简模板，避免系统 DefaultButtonStyle 在 PointerOver 用内部动画盖住在代码里设置的 Background -->
        <Style x:Key="CaptionBarButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="#2B2B2B"/>
            <Setter Property="UseSystemFocusVisuals" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="CaptionBtnRoot"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{TemplateBinding CornerRadius}">
                            <ContentPresenter Content="{TemplateBinding Content}"
                                              ContentTransitions="{TemplateBinding ContentTransitions}"
                                              Foreground="{TemplateBinding Foreground}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Padding="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CaptionBarCloseButtonStyle" TargetType="Button" BasedOn="{StaticResource CaptionBarButtonStyle}">
            <Setter Property="Foreground" Value="#E06C75"/>
        </Style>
        <!-- 未打开 PRI 时左侧大按钮：底色偏浅；悬停时整钮浅紫 -->
        <Style x:Key="OpenPriFileButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="240"/>
            <Setter Property="MinHeight" Value="44"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Foreground" Value="#2B2B2B"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="UseSystemFocusVisuals" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootBorder" Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0">
                                                    <DiscreteObjectKeyFrame.Value>
                                                        <SolidColorBrush Color="#EAEAEA"/>
                                                    </DiscreteObjectKeyFrame.Value>
                                                </DiscreteObjectKeyFrame>
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootBorder" Storyboard.TargetProperty="BorderBrush">
                                                <DiscreteObjectKeyFrame KeyTime="0">
                                                    <DiscreteObjectKeyFrame.Value>
                                                        <SolidColorBrush Color="#E6E9EF"/>
                                                    </DiscreteObjectKeyFrame.Value>
                                                </DiscreteObjectKeyFrame>
                                            </ObjectAnimationUsingKeyFrames>
                                            <DoubleAnimation Storyboard.TargetName="RootBorder" Storyboard.TargetProperty="Opacity" To="1" Duration="0"/>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="PointerOver">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootBorder" Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0">
                                                    <DiscreteObjectKeyFrame.Value>
                                                        <SolidColorBrush Color="#EDE7F6"/>
                                                    </DiscreteObjectKeyFrame.Value>
                                                </DiscreteObjectKeyFrame>
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootBorder" Storyboard.TargetProperty="BorderBrush">
                                                <DiscreteObjectKeyFrame KeyTime="0">
                                                    <DiscreteObjectKeyFrame.Value>
                                                        <SolidColorBrush Color="#DCD0EC"/>
                                                    </DiscreteObjectKeyFrame.Value>
                                                </DiscreteObjectKeyFrame>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootBorder" Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0">
                                                    <DiscreteObjectKeyFrame.Value>
                                                        <SolidColorBrush Color="#E1D5EE"/>
                                                    </DiscreteObjectKeyFrame.Value>
                                                </DiscreteObjectKeyFrame>
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootBorder" Storyboard.TargetProperty="BorderBrush">
                                                <DiscreteObjectKeyFrame KeyTime="0">
                                                    <DiscreteObjectKeyFrame.Value>
                                                        <SolidColorBrush Color="#CFC0E0"/>
                                                    </DiscreteObjectKeyFrame.Value>
                                                </DiscreteObjectKeyFrame>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Disabled">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="RootBorder" Storyboard.TargetProperty="Opacity" To="0.45" Duration="0"/>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <Border x:Name="RootBorder"
                                    Background="#EAEAEA"
                                    BorderBrush="#E6E9EF"
                                    BorderThickness="1"
                                    CornerRadius="6">
                                <ContentPresenter Content="{TemplateBinding Content}"
                                                  ContentTransitions="{TemplateBinding ContentTransitions}"
                                                  Foreground="{TemplateBinding Foreground}"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                  Padding="{TemplateBinding Padding}"/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="FastMenuFlyoutPresenterStyle" TargetType="MenuFlyoutPresenter">
            <Setter Property="Transitions">
                <Setter.Value>
                    <TransitionCollection />
                </Setter.Value>
            </Setter>
        </Style>
        <contract5NotPresent:DataTemplate x:Key="ResourceTemplateOld" x:DataType="models:ResourceItem">
            <muxc:TreeViewItemWrapper AutomationProperties.Name="{x:Bind DisplayName, Mode = OneWay}"
                          ItemsSource="{x:Bind Children}" Margin="0,2,0,2" Background="Transparent">
                <StackPanel Orientation="Horizontal">
                    <Image Width="28" Source="{x:Bind Icon, Mode = OneWay}" Margin="0,0,10,0"/>
                    <TextBlock Text="{x:Bind DisplayName, Mode = OneWay}" VerticalAlignment="Center" />
                </StackPanel>
                <muxc:TreeViewItemWrapper.ContextFlyout>
                    <MenuFlyout AreOpenCloseAnimationsEnabled="False"
                                MenuFlyoutPresenterStyle="{StaticResource FastMenuFlyoutPresenterStyle}">
                        <MenuFlyoutItem Text="{CustomResource Tree.NewResource}" Visibility="{x:Bind IsFolder}" Click="AddResource_Click">
                            <MenuFlyoutItem.Icon>
                                <SymbolIcon Symbol="Add"/>
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem Text="{CustomResource Tree.CopyResourceName}" Click="CopyResourceName_Click">
                            <MenuFlyoutItem.Icon>
                                <SymbolIcon Symbol="Copy"/>
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem Text="{CustomResource Common.Export}" Visibility="{x:Bind IsFolder, Converter={StaticResource InverseBooleanToVisibilityConverter}}" Click="ExportCurrentSelectedFromTree_Click">
                            <MenuFlyoutItem.Icon>
                                <SymbolIcon Symbol="Save"/>
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem Text="{CustomResource Tree.BatchExport}" Visibility="{x:Bind IsFolder}" Click="BatchExport_Click">
                            <MenuFlyoutItem.Icon>
                                <SymbolIcon Symbol="Save"/>
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem Text="{CustomResource Tree.SimpleRename}" Click="SimpleRename_Click">
                            <MenuFlyoutItem.Icon>
                                <SymbolIcon Symbol="Rename"/>
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem Text="{CustomResource Tree.FullRename}" Click="FullRename_Click">
                            <MenuFlyoutItem.Icon>
                                <SymbolIcon Symbol="Rename"/>
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem Text="{CustomResource Common.Delete}" Click="RemoveResources_Click">
                            <MenuFlyoutItem.Icon>
                                <SymbolIcon Symbol="Delete"/>
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                    </MenuFlyout>
                </muxc:TreeViewItemWrapper.ContextFlyout>
            </muxc:TreeViewItemWrapper>
        </contract5NotPresent:DataTemplate>

        <contract5Present:DataTemplate x:Key="ResourceTemplate" x:DataType="models:ResourceItem">
            <muxc:TreeViewItem AutomationProperties.Name="{x:Bind DisplayName, Mode = OneWay}"
                        ItemsSource="{x:Bind Children}" Margin="0,2,0,2" Background="Transparent">
                <StackPanel Orientation="Horizontal">
                    <Image Width="28" Source="{x:Bind Icon, Mode = OneWay}" Margin="0,0,10,0"/>
                    <TextBlock Text="{x:Bind DisplayName, Mode = OneWay}" VerticalAlignment="Center" />
                </StackPanel>
                <muxc:TreeViewItem.ContextFlyout>
                    <MenuFlyout AreOpenCloseAnimationsEnabled="False"
                                MenuFlyoutPresenterStyle="{StaticResource FastMenuFlyoutPresenterStyle}">
                        <MenuFlyoutItem Text="{CustomResource Tree.NewResource}" Visibility="{x:Bind IsFolder}" Click="AddResource_Click">
                            <MenuFlyoutItem.Icon>
                                <SymbolIcon Symbol="Add"/>
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem Text="{CustomResource Tree.CopyResourceName}" Click="CopyResourceName_Click">
                            <MenuFlyoutItem.Icon>
                                <SymbolIcon Symbol="Copy"/>
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem Text="{CustomResource Common.Export}" Visibility="{x:Bind IsFolder, Converter={StaticResource InverseBooleanToVisibilityConverter}}" Click="ExportCurrentSelectedFromTree_Click">
                            <MenuFlyoutItem.Icon>
                                <SymbolIcon Symbol="Save"/>
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem Text="{CustomResource Tree.BatchExport}" Visibility="{x:Bind IsFolder}" Click="BatchExport_Click">
                            <MenuFlyoutItem.Icon>
                                <SymbolIcon Symbol="Save"/>
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem Text="{CustomResource Tree.SimpleRename}" Click="SimpleRename_Click">
                            <MenuFlyoutItem.Icon>
                                <SymbolIcon Symbol="Rename"/>
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem Text="{CustomResource Tree.FullRename}" Click="FullRename_Click">
                            <MenuFlyoutItem.Icon>
                                <SymbolIcon Symbol="Rename"/>
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem Text="{CustomResource Common.Delete}" Click="RemoveResources_Click">
                            <MenuFlyoutItem.Icon>
                                <SymbolIcon Symbol="Delete"/>
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                    </MenuFlyout>
                </muxc:TreeViewItem.ContextFlyout>
            </muxc:TreeViewItem>
        </contract5Present:DataTemplate>

        <selectors:ResourceItemTemplateSelector x:Key="ResourceItemTemplateSelector"
            selectorsContract5Present:Resource="{StaticResource ResourceTemplate}"
            selectorsContract5NotPresent:Resource="{StaticResource ResourceTemplateOld}"/>
    </Page.Resources>

    <Grid Background="Transparent" AllowDrop="True" DragOver="Grid_DragOver" Drop="Grid_Drop">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border x:Name="CaptionBarRoot"
                Grid.Row="0"
                Margin="0,0,0,0"
                CornerRadius="0"
                BorderThickness="0,0,0,1"
                Padding="8,6"
                PointerPressed="CaptionBar_PointerPressed">
            <Border.Background>
                <SolidColorBrush Color="#DEE3E9" />
            </Border.Background>
            <Border.BorderBrush>
                <SolidColorBrush Color="#C8D0DA"/>
            </Border.BorderBrush>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0,8,0">
                    <FontIcon Glyph="&#xE8A5;" FontSize="14" Margin="0,0,6,0" Foreground="#333333"/>
                    <TextBlock Text="MrmTool" FontSize="13" FontWeight="SemiBold" Foreground="#333333"/>
                </StackPanel>

                <Grid Grid.Column="1">
                    <Border Background="#01000000" PointerPressed="CaptionBarBlankDrag_PointerPressed"/>
                    <Grid VerticalAlignment="Center" HorizontalAlignment="Stretch">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                    <muxc:MenuBar x:Name="TopMenuBar"
                                  Grid.Column="0"
                                  VerticalAlignment="Center"
                                  HorizontalAlignment="Left"
                                  Background="Transparent"
                                  IsTabStop="False"
                                  RequestedTheme="Light">
                        <muxc:MenuBarItem Title="{CustomResource Menu.File}" UseSystemFocusVisuals="False" IsTabStop="False">
                <MenuFlyoutItem Text="{CustomResource Menu.File.Open}" Click="Open_Click">
                    <MenuFlyoutItem.Icon>
                        <SymbolIcon Symbol="OpenFile"/>
                    </MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
                <MenuFlyoutItem x:Name="SaveMenuFlyoutItem" Text="{CustomResource Menu.File.Save}" Click="Save_Click">
                    <MenuFlyoutItem.Icon>
                        <SymbolIcon Symbol="Save"/>
                    </MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
                <MenuFlyoutItem x:Name="SaveAsMenuFlyoutItem" Text="{CustomResource Menu.File.SaveAs}" Click="SaveAs_Click">
                    <MenuFlyoutItem.Icon>
                        <SymbolIcon Symbol="SaveLocal"/>
                    </MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
                <MenuFlyoutSeparator/>
                <MenuFlyoutItem Text="{CustomResource Menu.File.Exit}" Click="Exit_Click">
                    <MenuFlyoutItem.Icon>
                        <SymbolIcon Symbol="Cancel"/>
                    </MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
                    </muxc:MenuBarItem>
                    <muxc:MenuBarItem Title="{CustomResource Menu.Edit}" UseSystemFocusVisuals="False" IsTabStop="False">
                <MenuFlyoutItem x:Name="NewResourceMenuFlyoutItem" Text="{CustomResource Menu.Edit.NewResource}" Click="AddResource_Click">
                    <MenuFlyoutItem.Icon>
                        <SymbolIcon Symbol="Add"/>
                    </MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
                <MenuFlyoutItem x:Name="RemoveResourcesItem" Text="{CustomResource Menu.Edit.DeleteSelected}" IsEnabled="False" Click="RemoveResources_Click">
                    <MenuFlyoutItem.Icon>
                        <SymbolIcon Symbol="Delete"/>
                    </MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
                <MenuFlyoutSeparator/>
                <MenuFlyoutItem x:Name="BatchImportMenuFlyoutItem" Text="{CustomResource Menu.Edit.BatchImport}" Click="BatchImport_Click">
                    <MenuFlyoutItem.Icon>
                        <SymbolIcon Symbol="ImportAll"/>
                    </MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
                <MenuFlyoutItem x:Name="BatchExportMenuFlyoutItem" Text="{CustomResource Menu.Edit.BatchExport}" Click="BatchExport_Click">
                    <MenuFlyoutItem.Icon>
                        <SymbolIcon Symbol="Save"/>
                    </MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
                <MenuFlyoutSeparator/>
                <MenuFlyoutItem Text="{CustomResource Menu.Edit.SetRootFolder}" Click="SetRootFolder_Click">
                    <MenuFlyoutItem.Icon>
                        <SymbolIcon Symbol="OpenLocal"/>
                    </MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
                <MenuFlyoutItem Text="{CustomResource Menu.Edit.EmbedPaths}" Click="EmbedPathResources_Click">
                    <MenuFlyoutItem.Icon>
                        <SymbolIcon Symbol="ImportAll"/>
                    </MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
                    </muxc:MenuBarItem>
                    <muxc:MenuBarItem Title="{CustomResource Menu.View}" UseSystemFocusVisuals="False" IsTabStop="False">
                <ToggleMenuFlyoutItem Visibility="{x:Bind local:Program.IsWebViewAvailable}" Text="{CustomResource Menu.View.UseWebViewSvg}" Click="UseWebViewForSvg_Click">
                    <ToggleMenuFlyoutItem.Icon>
                        <SymbolIcon Symbol="Globe"/>
                    </ToggleMenuFlyoutItem.Icon>
                </ToggleMenuFlyoutItem>
                <MenuFlyoutSubItem Text="{CustomResource Menu.View.PreviewTheme}">
                    <muxc:RadioMenuFlyoutItem Text="{CustomResource Menu.View.Theme.System}" GroupName="PreviewerTheme" Click="SystemTheme_Click" IsChecked="True" />
                    <muxc:RadioMenuFlyoutItem Text="{CustomResource Menu.View.Theme.Light}" GroupName="PreviewerTheme" Click="LightTheme_Click" />
                    <muxc:RadioMenuFlyoutItem Text="{CustomResource Menu.View.Theme.Dark}" GroupName="PreviewerTheme" Click="DarkTheme_Click" />
                    <MenuFlyoutSubItem.Icon>
                        <FontIcon Glyph="&#xF08C;" />
                    </MenuFlyoutSubItem.Icon>
                </MenuFlyoutSubItem>
                    </muxc:MenuBarItem>
                    <muxc:MenuBarItem Title="{CustomResource Menu.Language}" UseSystemFocusVisuals="False" IsTabStop="False">
                <muxc:RadioMenuFlyoutItem x:Name="LanguageChineseMenuItem"
                                          Text="{CustomResource Menu.Language.Chinese}"
                                          GroupName="AppLanguage"
                                          Click="LanguageChinese_Click" />
                <muxc:RadioMenuFlyoutItem x:Name="LanguageEnglishMenuItem"
                                          Text="{CustomResource Menu.Language.English}"
                                          GroupName="AppLanguage"
                                          Click="LanguageEnglish_Click" />
                    </muxc:MenuBarItem>
                    <muxc:MenuBarItem Title="{CustomResource Menu.Help}" UseSystemFocusVisuals="False" IsTabStop="False">
                <MenuFlyoutItem Text="{CustomResource Menu.Help.Usage}" Click="Usage_Click">
                    <MenuFlyoutItem.Icon>
                        <SymbolIcon Symbol="Help"/>
                    </MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
                <MenuFlyoutSeparator/>
                <MenuFlyoutItem Text="{CustomResource Menu.Help.Notice}" Click="Notice_Click">
                    <MenuFlyoutItem.Icon>
                        <SymbolIcon Symbol="ContactInfo"/>
                    </MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
                        </muxc:MenuBarItem>
                    </muxc:MenuBar>
                    <TextBlock x:Name="CurrentFilePathTextBlock"
                               Grid.Column="1"
                               Margin="12,0,8,0"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Stretch"
                               FontSize="12"
                               Foreground="#666666"
                               Text="{CustomResource Status.NoFileOpened}"
                               TextTrimming="CharacterEllipsis"
                               IsHitTestVisible="False"/>
                    </Grid>
                </Grid>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0">
                    <Button x:Name="minimizeButton"
                            Style="{StaticResource CaptionBarButtonStyle}"
                            ToolTipService.ToolTip="{CustomResource TitleBar.Minimize}"
                            PointerEntered="CaptionButton_PointerEntered"
                            PointerExited="CaptionButton_PointerExited"
                            PointerPressed="CaptionButton_PointerPressed"
                            PointerReleased="CaptionButton_PointerReleased"
                            Click="MinimizeWindow_Click">
                        <FontIcon Glyph="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                    </Button>
                    <Button x:Name="maximizeRestoreButton"
                            Style="{StaticResource CaptionBarButtonStyle}"
                            ToolTipService.ToolTip="{CustomResource TitleBar.MaxRestore}"
                            PointerEntered="CaptionButton_PointerEntered"
                            PointerExited="CaptionButton_PointerExited"
                            PointerPressed="CaptionButton_PointerPressed"
                            PointerReleased="CaptionButton_PointerReleased"
                            Click="ToggleMaximizeWindow_Click">
                        <FontIcon x:Name="maximizeRestoreIcon" Glyph="&#xE922;" FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                    </Button>
                    <Button x:Name="closeButton"
                            Style="{StaticResource CaptionBarCloseButtonStyle}"
                            ToolTipService.ToolTip="{CustomResource TitleBar.Close}"
                            PointerEntered="CaptionButton_PointerEntered"
                            PointerExited="CaptionButton_PointerExited"
                            PointerPressed="CaptionButton_PointerPressed"
                            PointerReleased="CaptionButton_PointerReleased"
                            Click="CloseWindow_Click">
                        <FontIcon Glyph="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" MinWidth="280"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid x:Name="leftTreeHeaderRow" Grid.Row="0" Margin="8,0,8,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="treeSearchBox"
                             PlaceholderText="{CustomResource Search.Placeholder}"
                             KeyDown="TreeSearchBox_KeyDown"
                             RightTapped="TreeSearchBox_RightTapped"/>
                    <Button Grid.Column="1" Margin="8,0,0,0" Content="{CustomResource Search.Button}" Click="TreeSearchButton_Click"/>
                    <Button Grid.Column="2" Margin="8,0,0,0" Content="{CustomResource Common.Clear}" Click="TreeSearchClear_Click"/>
                </Grid>

                <muxc:TreeView x:Name="treeView"
                               Grid.Row="1"
                               CanDragItems="False"
                               CanReorderItems="False"
                               ScrollViewer.VerticalScrollBarVisibility="Visible"
                               ItemsSource="{x:Bind ResourceItems}"
                               ItemTemplateSelector="{StaticResource ResourceItemTemplateSelector}"
                               SelectionChanged="treeView_SelectionChanged"/>

                <!-- 未加载 PRI 时：在左侧区域居中显示大按钮（与启动页「打开 PRI」等价） -->
                <Grid x:Name="emptyPriPlaceholder"
                      Grid.Row="0"
                      Grid.RowSpan="2"
                      Visibility="Collapsed"
                      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
                      Canvas.ZIndex="5">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Padding="20">
                        <TextBlock Text="{CustomResource Empty.NoPriOpened}"
                                   HorizontalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   FontSize="14"
                                   Margin="0,0,0,12"/>
                        <Button Content="{CustomResource Empty.OpenPriFile}"
                                Style="{StaticResource OpenPriFileButtonStyle}"
                                HorizontalAlignment="Center"
                                Click="Open_Click"/>
                    </StackPanel>
                </Grid>
            </Grid>

            <Grid Grid.Column="2" VerticalAlignment="Stretch">
                <Grid.RowDefinitions>
                    <RowDefinition Height="180" MinHeight="130"/>
                    <RowDefinition Height="6"/>
                    <RowDefinition Height="*" MinHeight="130"/>
                </Grid.RowDefinitions>
                
                <Border Grid.Row="0" Margin="16,0,10.5,10.5" BorderThickness="0.5" CornerRadius="8">
                    <Border.BorderBrush>
                        <SolidColorBrush Color="{ThemeResource TextFillColorSecondary}" Opacity="0.4"/>
                    </Border.BorderBrush>
                    <Grid>
                        <ListView x:Name="candidatesList" SelectionChanged="candidatesList_SelectionChanged">
                            <ListView.Header>
                                <Border Background="{ThemeResource SolidBackgroundFillColorTertiaryBrush}">
                                    <interactivity:Interaction.Behaviors>
                                        <behaviors:StickyHeaderBehavior/>
                                    </interactivity:Interaction.Behaviors>

                                        <wct:DataTable Margin="10,0,0,0" Height="30">
                                            <wct:DataColumn Content="{CustomResource Candidates.Type}" Width="120" MinWidth="100" CanResize="True"/>
                                            <wct:DataColumn Content="{CustomResource Candidates.Qualifier}"/>
                                    </wct:DataTable>
                                </Border>
                            </ListView.Header>

                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Left" />
                                    <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                                </Style>
                            </ListView.ItemContainerStyle>

                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:CandidateItem">
                                    <Grid Background="Transparent">
                                        <wct:DataRow HorizontalAlignment="Left">
                                            <TextBlock Text="{x:Bind Type, Mode = OneWay}" VerticalAlignment="Center"/>
                                            <TextBlock Text="{x:Bind Qualifiers, Mode = OneWay}" VerticalAlignment="Center"/>
                                        </wct:DataRow>

                                        <Grid.ContextFlyout>
                                            <MenuFlyout>
                                                <MenuFlyoutItem Text="{CustomResource Common.Export}" Visibility="{x:Bind IsExportable, Mode = OneWay}" Click="ExportButton_Click">
                                                    <MenuFlyoutItem.Icon>
                                                        <SymbolIcon Symbol="Save"/>
                                                    </MenuFlyoutItem.Icon>
                                                </MenuFlyoutItem>
                                                <MenuFlyoutItem Text="{CustomResource Candidate.ShowInExplorer}" Visibility="{x:Bind IsPathCandidate, Mode = OneWay}" Click="OpenFolder_Click">
                                                    <MenuFlyoutItem.Icon>
                                                        <SymbolIcon Symbol="Folder"/>
                                                    </MenuFlyoutItem.Icon>
                                                </MenuFlyoutItem>
                                                <MenuFlyoutItem Text="{CustomResource Candidate.TryEmbedToPri}" Visibility="{x:Bind IsPathCandidate, Mode = OneWay}" Click="EmbedPathCandidate_Click">
                                                    <MenuFlyoutItem.Icon>
                                                        <SymbolIcon Symbol="Import"/>
                                                    </MenuFlyoutItem.Icon>
                                                </MenuFlyoutItem>
                                                <MenuFlyoutItem Text="{CustomResource Common.Edit}" Click="CreateOrModifyCandidate_Click">
                                                    <MenuFlyoutItem.Icon>
                                                        <SymbolIcon Symbol="Edit"/>
                                                    </MenuFlyoutItem.Icon>
                                                </MenuFlyoutItem>
                                                <MenuFlyoutItem Text="{CustomResource Common.Delete}" Click="DeleteCandiate_Click">
                                                    <MenuFlyoutItem.Icon>
                                                        <SymbolIcon Symbol="Delete"/>
                                                    </MenuFlyoutItem.Icon>
                                                </MenuFlyoutItem>
                                            </MenuFlyout>
                                        </Grid.ContextFlyout>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <Viewbox ToolTipService.ToolTip="{CustomResource Candidate.Add}" Width="28" Height="28" Margin="0,2,2,0" VerticalAlignment="Top" HorizontalAlignment="Right" Tapped="CreateOrModifyCandidate_Click">
                            <Grid Padding="5" Background="Transparent">
                                <SymbolIcon x:Name="addSymbol" Symbol="Add"/>
                            </Grid>

                            <Viewbox.Resources>
                                <SineEase x:Name="easingFunction" EasingMode="EaseIn"/>

                                <Storyboard x:Name="HoverBoard">
                                    <ColorAnimation Duration="0:0:0.2" From="{ThemeResource SystemBaseHighColor}" To="IndianRed"
                                        Storyboard.TargetProperty="(UIElement.Foreground).(SolidColorBrush.Color)"
                                        Storyboard.TargetName="addSymbol" EasingFunction="{StaticResource easingFunction}"
                                        d:IsOptimized="True"/>
                                </Storyboard>

                                <Storyboard x:Name="UnhoverBoard">
                                    <ColorAnimation Duration="0:0:0.2" From="IndianRed" To="{ThemeResource SystemBaseHighColor}"
                                        Storyboard.TargetProperty="(UIElement.Foreground).(SolidColorBrush.Color)"
                                        Storyboard.TargetName="addSymbol" EasingFunction="{StaticResource easingFunction}"
                                        d:IsOptimized="True"/>
                                </Storyboard>
                            </Viewbox.Resources>

                            <interactivity:Interaction.Behaviors>
                                <mbehaviors:PointerEnteredBehavior>
                                    <interactivity:ControlStoryboardAction Storyboard="{StaticResource UnhoverBoard}" ControlStoryboardOption="Stop"/>
                                    <interactivity:ControlStoryboardAction Storyboard="{StaticResource HoverBoard}" ControlStoryboardOption="Play"/>
                                </mbehaviors:PointerEnteredBehavior>

                                <mbehaviors:PointerExitedBehavior>
                                    <interactivity:ControlStoryboardAction Storyboard="{StaticResource HoverBoard}" ControlStoryboardOption="Stop"/>
                                    <interactivity:ControlStoryboardAction Storyboard="{StaticResource UnhoverBoard}" ControlStoryboardOption="Play"/>
                                </mbehaviors:PointerExitedBehavior>
                            </interactivity:Interaction.Behaviors>
                        </Viewbox>
                    </Grid>
                </Border>

                <Border x:Name="PreviewContainer" Grid.Row="2" Margin="16,0,10.5,10.5" BorderThickness="0.5" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}" CornerRadius="8">
                    <contract7Present:Border.BackgroundTransition>
                        <contract7Present:BrushTransition/>
                    </contract7Present:Border.BackgroundTransition>
                    <Border.BorderBrush>
                        <SolidColorBrush Color="{ThemeResource TextFillColorSecondary}" Opacity="0.4"/>
                    </Border.BorderBrush>
                    <Grid>
                        <!-- String values -->
                        <winuieditor:CodeEditorControl d:Visibility="Collapsed"
                                                      Padding="-10,12,0,0"
                                                      x:Name="valueTextEditor"
                                                      SyntaxHighlightingApplied="SyntaxHighlightingApplied"
                                                      RightTapped="ValueTextEditor_RightTapped"
                                                      x:Load="False" />
                        <TextBox x:Name="valueTextBox"
                                 Visibility="Collapsed"
                                 Margin="12"
                                 FontSize="15"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 IsSpellCheckEnabled="False"
                                 TextChanged="ValueTextBox_TextChanged"
                                 RightTapped="ValueTextBox_RightTapped">
                        </TextBox>
                        
                        <!-- Path error: Invalid root -->
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" d:Visibility="Collapsed" x:Load="False" x:Name="invalidRootPathContainer">
                            <TextBlock TextWrapping="Wrap" Text="{CustomResource Preview.InvalidRoot}" HorizontalAlignment="Center" />
                            <Button Content="{CustomResource Menu.Edit.SetRootFolderShort}" HorizontalAlignment="Center" Margin="0,10,0,0" Click="SetRootFolder_Click" />
                        </StackPanel>

                        <!-- Path error: Failed to open file -->
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Padding="20" x:Load="False" Visibility="Collapsed" x:Name="failedToOpenFileContainer">
                            <TextBlock TextWrapping="Wrap" HorizontalAlignment="Center" >
                                <Run Text="{CustomResource Preview.FailedOpen.Prefix}"/> <Bold>&quot;<Run x:Name="failedFileNameRun"/>&quot;</Bold><Run Text="{CustomResource Preview.FailedOpen.Suffix}"/>
                                <LineBreak/>
                                <LineBreak/>
                                <Bold><Run Text="{CustomResource Preview.FailedOpen.ExceptionLabel}"/></Bold> <Run x:Name="failedExceptionMessageRun"/>
                            </TextBlock>
                            <Button Content="{CustomResource Common.Retry}" HorizontalAlignment="Center" Margin="0,20,0,0" Click="TryAgain_Click" />
                        </StackPanel>

                        <!-- Path fallback -->
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" d:Visibility="Collapsed" x:Load="False" x:Name="openFolderContainer">
                            <Button Content="{CustomResource Candidate.ShowInExplorer}" HorizontalAlignment="Center" Click="OpenFolder_Click" />
                        </StackPanel>

                        <!-- Embedded data fallback -->
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" d:Visibility="Collapsed" x:Load="False" x:Name="exportContainer">
                            <TextBlock x:Name="fileSizeLabel" HorizontalAlignment="Center" />
                            <Button Content="{CustomResource Preview.ExportToDisk}" HorizontalAlignment="Center" Margin="0,10,0,0" Click="ExportButton_Click" />
                        </StackPanel>

                        <!-- XBF fallback -->
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Padding="20" x:Load="False" Visibility="Collapsed" x:Name="xbfFallbackContainer">
                            <TextBlock TextWrapping="Wrap" HorizontalAlignment="Center" >
                                <Run Text="{CustomResource Preview.FailedXbf.Prefix}"/> <Bold>&quot;<Run x:Name="xbfFileNameRun"/>&quot;</Bold><Run Text="{CustomResource Preview.FailedXbf.Suffix}"/>
                                <LineBreak/>
                                <LineBreak/>
                                <Bold><Run Text="{CustomResource Preview.FailedXbf.ExceptionLabel}"/></Bold> <Run x:Name="failedXbfExceptionMessageRun"/>
                            </TextBlock>
                            <Button Content="{CustomResource Preview.ExportToDisk}" HorizontalAlignment="Center" Margin="0,20,0,0" Click="ExportButton_Click" />
                        </StackPanel>

                        <!-- Image Previewer -->
                        <ScrollViewer x:Name="imagePreviewerContainer" d:Visibility="Collapsed" x:Load="False" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" HorizontalScrollBarVisibility="Visible" HorizontalScrollMode="Auto" VerticalScrollMode="Auto" ZoomMode="Enabled" IsZoomInertiaEnabled="True">
                            <Image x:Name="imagePreviewer" Stretch="None" />
                        </ScrollViewer>
                        
                        <!-- SVG Previewer -->
                        <ScrollViewer x:Name="svgPreviewerContainer" d:Visibility="Collapsed" x:Load="False" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" HorizontalScrollBarVisibility="Visible" HorizontalScrollMode="Auto" VerticalScrollMode="Auto" ZoomMode="Enabled" IsZoomInertiaEnabled="True">
                            <ContentPresenter x:Name="svgPreviewer" />
                        </ScrollViewer>

                        <WebView x:Name="webView" d:Visibility="Collapsed" x:Load="False" DefaultBackgroundColor="Transparent" />
                    </Grid>
                </Border>

                <wct:GridSplitter Grid.Row="1"
                                  Height="6"
                                  MinHeight="4"
                                  ResizeBehavior="BasedOnAlignment"
                                  ResizeDirection="Rows"
                                  Background="Transparent">
                    <wct:GridSplitter.Element>
                        <TextBlock Text="&#xE76F;" FontFamily="Segoe MDL2 Assets" FontSize="10" IsHitTestVisible="False" Opacity="0.45" VerticalAlignment="Center" HorizontalAlignment="Center" TextAlignment="Center"/>
                    </wct:GridSplitter.Element>
                </wct:GridSplitter>
            </Grid>

            <wct:GridSplitter Grid.Column="1"
                              Width="6"
                              MinWidth="4"
                              ResizeBehavior="BasedOnAlignment"
                              ResizeDirection="Auto"
                              Background="Transparent">
                <wct:GridSplitter.Element>
                    <Rectangle Fill="{ThemeResource ButtonForegroundThemeBrush}" Width="0.5" Opacity="0.14" VerticalAlignment="Stretch" HorizontalAlignment="Center"/>
                </wct:GridSplitter.Element>
            </wct:GridSplitter>
        </Grid>

        <!-- 页面内模态层：替代 ContentDialog，避免宿主环境下弹窗不可见。Canvas.ZIndex 保证叠在分割器等之上；原生预览需在代码中临时 Unload，否则会盖住面板。 -->
        <!-- 使用 Grid + Children.Add 挂载模态内容。ContentPresenter.Content 在托管 CoreWindow 下对代码构造的 Grid 赋值易 E_NOINTERFACE。 -->
        <Grid x:Name="pageModalOverlay" Grid.Row="0" Grid.RowSpan="2" Visibility="Collapsed" Background="#99000000" Canvas.ZIndex="10000">
            <Grid x:Name="pageModalHost" HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="960" MaxHeight="900"/>
        </Grid>
    </Grid>
</Page>
